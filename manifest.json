{
  "manifest_version": 3,
  "name": "DC Collection Tool",
  "version": "1.1.0",
  "description": "Partial Payment eligibility engine for DC agents",
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": [
    "https://collections.scredit.in.th/*",
    "https://script.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://collections.scredit.in.th/main/case/detail/*"],
      "js": ["config.js", "eligibility.js", "content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
